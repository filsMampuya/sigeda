{
  "apphosting": [
    {
      "backendId": "sigeda-web",
      "rootDir": "apps/web",
      "ignore": [
        "node_modules",
        ".git",
        ".codex-tmp",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" install",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "firestore": {
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "storage": {
    "rules": "firebase/storage.rules"
  }
}
